import Link from 'next/link';
import {JournalCard} from '@/components/journals/journal-card';
import {getAllJournals} from '@/lib/journals';
import {
  getLatestLegislation,
  normalizeLocale,
  pickLocalizedText
} from '@/lib/legislation';

type Props = {
  params: Promise<{locale: string}>;
};

function getCopy(locale: string) {
  if (locale === 'uz') {
    return {
      badge: 'Akademik platforma',
      title: 'Ilmiy jurnallar va nashrlar bo‘yicha premium navigatsiya platformasi',
      subtitle:
        'Jurnallar katalogi, Scopus va OAK bo‘yicha yo‘riqnoma, foydali materiallar, rasmiy manbalar va maqola chop etish uchun qulay aloqa ssenariysi.',
      searchPlaceholder: 'Jurnal nomi yoki nashriyot bo‘yicha qidiruv',
      searchButton: 'Jurnal topish',
      openCatalog: 'Katalogni ochish',
      contactUs: 'Bog‘lanish',
      quickLinks: 'Tezkor bo‘limlar',
      featuredTitle: 'Tavsiya etilgan jurnallar',
      featuredDescription: 'Tez boshlash uchun tanlangan jurnallar.',
      latestTitle: 'So‘nggi hujjatlar',
      latestDescription: 'Asosiy normativ materiallar va rasmiy manbalar.',
      ctaTitle: 'Nashr bo‘yicha yordam kerakmi?',
      ctaText:
        'Jurnal tanlash, talablarni tushunish va maqola yuborish bo‘yicha biz bilan bog‘laning.',
      ctaButton: 'Kontaktlar bo‘limiga o‘tish',
      disclaimerTitle: 'Muhim eslatma',
      disclaimerText:
        'Platforma ma’lumot uchun xizmat qiladi va nashrni kafolatlamaydi. Yakuniy tekshiruvni har doim rasmiy manbalar orqali bajaring.',
      readMore: 'Batafsil',
      journals: 'Jurnallar'
    };
  }

  if (locale === 'en') {
    return {
      badge: 'Academic platform',
      title: 'A premium platform for navigating scientific journals and publications',
      subtitle:
        'A journal catalog, Scopus and SAC guidance, useful materials, official sources, and a convenient contact flow for article publication.',
      searchPlaceholder: 'Search by journal title or publisher',
      searchButton: 'Find journal',
      openCatalog: 'Open catalog',
      contactUs: 'Contact us',
      quickLinks: 'Quick sections',
      featuredTitle: 'Featured journals',
      featuredDescription: 'A selected set of journals for a quick start.',
      latestTitle: 'Latest documents',
      latestDescription: 'Key regulatory materials and official sources.',
      ctaTitle: 'Need help with publication?',
      ctaText:
        'Contact us for journal selection, requirement clarification, and submission support.',
      ctaButton: 'Open contacts',
      disclaimerTitle: 'Important note',
      disclaimerText:
        'The platform provides reference information and does not guarantee publication. Always verify final details using official sources.',
      readMore: 'Read more',
      journals: 'Journals'
    };
  }

  return {
    badge: 'Академическая платформа',
    title: 'Премиальная платформа для навигации по научным журналам и публикациям',
    subtitle:
      'Каталог журналов, ориентиры по Scopus и ВАК, полезные материалы, официальные источники и удобный контактный сценарий для публикации статьи.',
    searchPlaceholder: 'Поиск по названию журнала или издателю',
    searchButton: 'Найти журнал',
    openCatalog: 'Открыть каталог',
    contactUs: 'Связаться',
    quickLinks: 'Быстрые разделы',
    featuredTitle: 'Рекомендуемые журналы',
    featuredDescription: 'Подборка журналов для быстрого старта.',
    latestTitle: 'Последние документы',
    latestDescription: 'Основные нормативные материалы и официальные источники.',
    ctaTitle: 'Нужна помощь с публикацией?',
    ctaText:
      'Свяжитесь с нами по вопросам выбора журнала, требований и сопровождения подачи статьи.',
    ctaButton: 'Перейти в контакты',
    disclaimerTitle: 'Важно',
    disclaimerText:
      'Платформа предоставляет справочную информацию и не гарантирует публикацию. Финальную проверку данных всегда выполняйте по официальным источникам.',
    readMore: 'Подробнее',
    journals: 'Журналы'
  };
}

export default async function LocaleHomePage({params}: Props) {
  const {locale: rawLocale} = await params;
  const locale = normalizeLocale(rawLocale);
  const copy = getCopy(locale);

  const journals = getAllJournals().slice(0, 6);
  const latestDocuments = getLatestLegislation(3);

  const quickLinks = [
    {href: `/${locale}/journals`, label: copy.journals},
    {href: `/${locale}/scopus`, label: 'Scopus'},
    {href: `/${locale}/oak`, label: locale === 'en' ? 'SAC' : 'OAK'},
    {
      href: `/${locale}/legislation`,
      label:
        locale === 'ru'
          ? 'Законодательство'
          : locale === 'uz'
          ? 'Qonunchilik'
          : 'Legislation'
    },
    {
      href: `/${locale}/useful`,
      label:
        locale === 'ru'
          ? 'Полезные данные'
          : locale === 'uz'
          ? 'Foydali ma’lumotlar'
          : 'Useful data'
    },
    {
      href: `/${locale}/contacts`,
      label:
        locale === 'ru'
          ? 'Контакты'
          : locale === 'uz'
          ? 'Kontaktlar'
          : 'Contacts'
    }
  ];

  return (
    <main>
      <section className="mx-auto max-w-7xl px-4 pt-10 sm:px-6 lg:px-8">
        <div className="rounded-3xl bg-[#1D4BAE] p-6 shadow-lg sm:p-8 lg:p-12">
          <div className="max-w-4xl">
            <div className="inline-flex rounded-full border border-white/30 bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-[#F6F1E8]">
              {copy.badge}
            </div>

            <h1 className="mt-5 text-4xl font-bold tracking-tight text-[#F6F1E8] sm:text-5xl lg:text-6xl">
              {copy.title}
            </h1>

            <p className="mt-5 max-w-3xl text-base leading-8 text-[#E9E0D3] sm:text-lg">
              {copy.subtitle}
            </p>

            <form
              action={`/${locale}/journals`}
              className="mt-8 flex flex-col gap-3 rounded-2xl bg-[#163B8A] p-3 sm:flex-row"
            >
              <input
                type="text"
                name="q"
                placeholder={copy.searchPlaceholder}
                className="w-full rounded-xl border border-[#2E5CC0] bg-[#F6F1E8] px-4 py-3 text-sm text-[#1E2A44] outline-none placeholder:text-[#7C879C] focus:border-white"
              />
              <button
                type="submit"
                className="rounded-xl bg-[#F6F1E8] px-5 py-3 text-sm font-semibold text-[#1D4BAE] transition hover:bg-[#FBF8F2]"
              >
                {copy.searchButton}
              </button>
            </form>

            <div className="mt-6 flex flex-wrap gap-3">
              <Link
                href={`/${locale}/journals`}
                className="inline-flex rounded-full bg-[#F6F1E8] px-5 py-3 text-sm font-semibold text-[#1D4BAE] transition hover:bg-[#FBF8F2]"
              >
                {copy.openCatalog}
              </Link>

              <Link
                href={`/${locale}/contacts`}
                className="inline-flex rounded-full border border-white/30 bg-transparent px-5 py-3 text-sm font-semibold text-[#F6F1E8] transition hover:bg-white/10"
              >
                {copy.contactUs}
              </Link>
            </div>
          </div>
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 pt-8 sm:px-6 lg:px-8">
        <div className="mb-5">
          <h2 className="text-2xl font-bold text-[#1E2A44]">{copy.quickLinks}</h2>
        </div>

        <div className="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {quickLinks.map((item) => (
            <Link
              key={item.href}
              href={item.href}
              className="rounded-2xl bg-[#1D4BAE] p-5 text-base font-semibold text-[#F6F1E8] shadow-sm transition hover:bg-[#163B8A]"
            >
              {item.label}
            </Link>
          ))}
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 pt-12 sm:px-6 lg:px-8">
        <div className="mb-6 flex items-end justify-between gap-4">
          <div>
            <h2 className="text-2xl font-bold text-[#1E2A44] sm:text-3xl">
              {copy.featuredTitle}
            </h2>
            <p className="mt-2 max-w-2xl text-sm leading-7 text-[#5E6B85]">
              {copy.featuredDescription}
            </p>
          </div>

          <div className="hidden rounded-full border border-[#E7DECF] bg-[#FBF8F2] px-4 py-2 text-sm text-[#5E6B85] sm:inline-flex">
            {copy.journals}: {journals.length}
          </div>
        </div>

        <div className="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
          {journals.map((journal) => (
            <JournalCard key={journal.id} journal={journal} locale={locale} />
          ))}
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 pt-12 sm:px-6 lg:px-8">
        <div className="mb-6">
          <h2 className="text-2xl font-bold text-[#1E2A44] sm:text-3xl">
            {copy.latestTitle}
          </h2>
          <p className="mt-2 max-w-2xl text-sm leading-7 text-[#5E6B85]">
            {copy.latestDescription}
          </p>
        </div>

        <div className="grid gap-6 lg:grid-cols-3">
          {latestDocuments.map((doc) => (
            <article
              key={doc.slug}
              className="rounded-2xl bg-[#1D4BAE] p-6 shadow-sm"
            >
              <h3 className="text-xl font-semibold text-[#F6F1E8]">
                {pickLocalizedText(doc.title, locale)}
              </h3>

              <p className="mt-3 text-sm leading-7 text-[#E9E0D3]">
                {pickLocalizedText(doc.summary, locale)}
              </p>

              <Link
                href={`/${locale}/legislation/${doc.slug}`}
                className="mt-5 inline-flex rounded-xl bg-[#F6F1E8] px-4 py-2 text-sm font-semibold text-[#1D4BAE] transition hover:bg-[#FBF8F2]"
              >
                {copy.readMore}
              </Link>
            </article>
          ))}
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 pt-12 sm:px-6 lg:px-8">
        <div className="rounded-3xl bg-[#1D4BAE] p-6 shadow-lg sm:p-8">
          <h2 className="text-2xl font-bold text-[#F6F1E8] sm:text-3xl">
            {copy.ctaTitle}
          </h2>

          <p className="mt-4 max-w-3xl text-sm leading-8 text-[#E9E0D3] sm:text-base">
            {copy.ctaText}
          </p>

          <Link
            href={`/${locale}/contacts`}
            className="mt-6 inline-flex rounded-full bg-[#F6F1E8] px-5 py-3 text-sm font-semibold text-[#1D4BAE] transition hover:bg-[#FBF8F2]"
          >
            {copy.ctaButton}
          </Link>
        </div>
      </section>

      <section className="mx-auto max-w-7xl px-4 pb-14 pt-12 sm:px-6 lg:px-8">
        <div className="rounded-3xl border border-[#E7DECF] bg-[#FBF8F2] p-6">
          <h2 className="text-xl font-semibold text-[#1E2A44]">
            {copy.disclaimerTitle}
          </h2>

          <p className="mt-3 max-w-4xl text-sm leading-7 text-[#5E6B85]">
            {copy.disclaimerText}
          </p>
        </div>
      </section>
    </main>
  );
}
